# --- Supabase (the runner uses service_role to write across users) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- APNs push ---
# Generate a .p8 key in the Apple Developer portal (Keys -> Apple Push Notifications).
APNS_KEY_PATH=/etc/doit/AuthKey_ABC123DEFG.p8
APNS_KEY_ID=ABC123DEFG
APNS_TEAM_ID=YOURTEAMID
APNS_TOPIC=com.yourcompany.doit       # iOS bundle id
APNS_USE_SANDBOX=true                  # set to false for production builds

# --- Loop tuning ---
POLL_INTERVAL_SECS=2
RUN_TIMEOUT_SECS=900                   # 15 min wall clock per run

# --- Hermes model settings applied from the app ---
HERMES_PROFILES_DIR=/home/doit/.hermes/profiles
HERMES_RESTART_COMMAND_TEMPLATE=sudo systemctl restart hermes-{profile}

# --- Global Doit model provider keys ---
# Users choose provider/model in Settings, but Doit pays for model usage.
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...

# --- Browserbase (Hermes browser automation + browse.sh CLI) ---
# Copy these into ~/.hermes/.env on the VM with hermes/scripts/sync_browserbase_env.py.
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# --- On-demand browse.sh skill bridge ---
# When true, the runner may install a matching browse.sh skill before starting
# Hermes for browser-heavy tasks so skills are visible at run start.
BROWSE_SKILL_AUTO_INSTALL=true
BROWSE_SKILL_INSTALL_TIMEOUT_SECS=30
# 0 means "use conservative task-shape rules"; reserved for future browse CLI
# ranking metadata if it becomes available.
BROWSE_SKILL_MIN_CONFIDENCE=0
# Optional override. Default is ../hermes/scripts/sync_browse_skill.py from the VM layout.
# BROWSE_SKILL_SYNC_SCRIPT=/opt/doit/hermes/scripts/sync_browse_skill.py
